# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
.pytest_cache/
.ruff_cache/

# Node
node_modules/

# Local state & secrets
.env
logs/

# Deploy output: installing a build (e.g. `npx moe install --dev`) writes the deployed skill +
# agents into the target host's config. In this repo that is regenerable install output, not
# source — the source lives in skill/, experts/, templates/, and dist/.
.claude/
.codex/
.agents/

# NOTE: dist/ and experts/*/knowledge/ and experts/*/materials/ are intentionally
# committed — the compiled per-host builds and curated knowledge travel with the repo
# (the impeccable.style model). Do not ignore them.
