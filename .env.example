# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# --- AWS Bedrock ---
# Region MUST serve Cohere Rerank 3.5: us-west-2 | ca-central-1 | eu-central-1 | ap-northeast-1
AWS_REGION=us-west-2
# Credentials come from the standard AWS chain (env vars, SSO, or instance role):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_PROFILE=...
# Optional per-service region overrides:
# BEDROCK_EMBED_REGION=us-west-2
# BEDROCK_RERANK_REGION=us-west-2
# BEDROCK_LLM_REGION=us-west-2

# --- Local state ---
MOE_DB_PATH=moe.db
MATERIALS_DIR=materials

# --- Dashboard ---
MOE_DASHBOARD_HOST=127.0.0.1
MOE_DASHBOARD_PORT=8848

# --- Retrieval tunables (optional) ---
# MOE_TOP_K=8
# MOE_ROUTE_THRESHOLD=0.30
# MOE_CONTEXTUAL_RETRIEVAL=true
